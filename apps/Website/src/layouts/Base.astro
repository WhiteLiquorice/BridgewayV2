---
import '../styles/global.css'

export interface Props {
  title?: string
  description?: string
  ogTitle?: string
  ogDescription?: string
}

const {
  title = 'Bridgeway — Practice Management Software',
  description = 'Bridgeway is practice management software for appointment-based businesses. Scheduling, client portal, walk-in queue, and more.',
  ogTitle = 'Bridgeway — Practice Management Software',
  ogDescription = 'Bridgeway is practice management software for appointment-based businesses. Scheduling, client portal, walk-in queue, and more.',
} = Astro.props
---
<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta property="og:title" content={ogTitle} />
    <meta property="og:description" content={ogDescription} />
    <meta property="og:type" content="website" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={ogTitle} />
    <meta name="twitter:description" content={ogDescription} />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:wght@400;500;600;700&family=Montserrat:wght@300;400;500;600;700&family=Inter:wght@400;500;600;700;800;900&family=Lora:wght@400;600;700&display=swap"
      rel="stylesheet"
    />
  </head>
  <body>
    <slot />
  </body>
</html>
