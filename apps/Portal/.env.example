# ── Shared Supabase project (same values as Dashboard, Booking, and Admin App) ─
# All four Bridgeway apps point at one Supabase project.
# Copy this file to .env.local and fill in your values.
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# The UUID of the org this Portal deployment belongs to.
# Used to load branding (name, color, logo) on the login page before auth.
# Requires anon SELECT on orgs(id, name, primary_color, logo_url) in Supabase.
VITE_ORG_ID=your-org-uuid-here
